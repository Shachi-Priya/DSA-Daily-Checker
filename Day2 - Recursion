# Practice Problem 4:--------------------------------------
Sum of 0 to n —>
function sum(curr, n){
    if(curr===n){
        return n;
    } 
    return sum(curr+1, n)+curr;
}
let result=sum(0,5); 
console.log("result::", result); // 1 2 3 4 5


# Recursion is parent of:
1. Backtracking - guided form of recursion
2. Dynamic Programming - top down/memoization is recursive. Bottom up/tabulation is iterative
3. Greedy Algorithms - recursion when try to optimise next step (short term)
4. Divide and conquer - divide into subproblems and solve each subproblems independently



# Complexity Analysis of Recursive Solution:
              O
	       /	\
          O      O
        /  \    /  \
       O   O    O   O
 TC = (no. of nodes) * (work done per node)
 
 If leaf nodes(LN) and other nodes(ON) are doing different tasks then,
 TC = (LN * LW) + (ON * OW)

 SC= O(n) (=depth of tree=recursive call stack=n)


# Problem 1:---------------------------------------------------
779. K-th Symbol in Grammar

https://leetcode.com/problems/k-th-symbol-in-grammar/description/

var kthGrammar = function(n, k) {
   // 0
   // 01
   // 0110
   // 01101001

   // TC : O(n) (=nodes*workpernode)
   // SC : O(n) (=recursion call stack)
   if(n===1) return 0;
   let len=2**(n-1);
   let mid=len/2;

   if(k<=mid){
       return kthGrammar(n-1, k);
   } else {
       return 1 - kthGrammar(n-1, k-mid);
   }

};


