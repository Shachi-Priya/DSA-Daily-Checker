# Practice Problem 1:---------------------------------------------------
Permutation of n distinct numbers in an array —>

function permutation(nums){
    // TC:- O(n*n!) [n depth for all n! permutations]
    // SC:- O(n) [n->recursive call stack]
    
    let res=[];
    function helper(i){
        if(i==nums.length-1){
            return res.push([...nums]);
        }
    
        for(let j=i;j<nums.length;j++){
            [nums[i],nums[j]]=[nums[j],nums[i]];
            helper(i+1);
            // backtracking
            [nums[i],nums[j]]=[nums[j],nums[i]];
        }
    }
    helper(0);
    return res;
}
let nums=[1,2,3];
let result=permutation(nums);
console.log(result);


# Practice Problem 2:---------------------------------------------------
Permutation of n numbers in an array, might contain duplicates —>

function permutation(nums){
    // TC:- O(n*n!) [n depth for all n! permutations]
    // SC:- O(n) [n->recursive call stack]
    
    let res=[];
    function helper(i){
        if(i==nums.length-1){
            return res.push([...nums]);
        }
    
        let hash={}
        for(let j=i;j<nums.length;j++){
            if(!hash[nums[j]]){
                hash[nums[j]]=1;
                [nums[i],nums[j]]=[nums[j],nums[i]];
                helper(i+1);
                // backtracking
                [nums[i],nums[j]]=[nums[j],nums[i]];
            }
        }
    }
    helper(0);
    return res;
}
let nums=[1,1,2];
let result=permutation(nums);
console.log(result);




